# ReClaw .gitignore - ignore runtime, memory, sensitive, builds
memory/.dreams/
.openclaw/
*.log
/tmp/
__pycache__/
*.pyc
node_modules/
dist/
.env
*.pid
dashboard/
.DS_Store
.idea/
.vscode/
*.bak
*.backup
*.eradicating*
secrets/
credentials/
# Ignore generated memory and session logs that may contain tokens
memory/dreaming/
memory/*.md  # keep only curated; runtime in rooms/
