# ReClaw 2.0 .env (copy to .env and edit)
RECLAW_ENV=dev
LOG_LEVEL=INFO

# Obsidian output (the whole point)
# Windows dev example:
# OBSIDIAN_VAULT_PATH=C:/Users/Jason/Desktop/Obsidian Claw
OBSIDIAN_VAULT_PATH=outputs/obsidian
OBSIDIAN_SUBDIR=Rural Data

# Data behavior
USE_LIVE_FETCH=false
FETCH_TIMEOUT=15
MAX_PROPERTIES_PER_COUNTY=80

# Future LLM
ENABLE_LLM_ANALYSIS=false
LLM_MODEL=llama3.1:8b

# Safety
WRITE_DRY_RUN=false
JOB_TIMEOUT_SECONDS=300
